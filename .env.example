# ============================================================================
# AI RESUME ANALYZER - ENVIRONMENT CONFIGURATION
# ============================================================================
# This file shows what environment variables you need to set.
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git (it contains secrets!)
# ============================================================================

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------
# These control how the application runs

# Backend server port (default: 8000)
BACKEND_PORT=8000

# Frontend server port (default: 3000)
FRONTEND_PORT=3000

# Environment: development, staging, or production
ENVIRONMENT=development

# Enable debug mode (shows detailed error messages)
# Set to false in production!
DEBUG=true

# ----------------------------------------------------------------------------
# AI PROVIDER API KEYS
# ----------------------------------------------------------------------------
# You need at least ONE of these to use AI analysis
# Get your keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/
# - Ollama: Run locally, no key needed

# OpenAI API Key (for GPT-4, GPT-3.5)
# Example: sk-proj-abc123...
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude 3)
# Example: sk-ant-api03-abc123...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Base URL (for local LLMs)
# Default: http://localhost:11434
# Only needed if you're running Ollama locally
OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------------------------
# DEFAULT AI PROVIDER
# ----------------------------------------------------------------------------
# Which AI provider to use by default
# Options: openai, anthropic, ollama
# Users can override this in the UI
DEFAULT_AI_PROVIDER=openai

# Default model for each provider
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_MODEL=claude-3-sonnet-20240229
OLLAMA_MODEL=llama2

# ----------------------------------------------------------------------------
# FILE UPLOAD SETTINGS
# ----------------------------------------------------------------------------
# Control file upload behavior

# Maximum file size in megabytes
MAX_FILE_SIZE_MB=10

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,docx

# Directory to store uploaded files temporarily
UPLOAD_DIR=./uploads

# ----------------------------------------------------------------------------
# ANALYSIS SETTINGS
# ----------------------------------------------------------------------------
# Configure analysis features

# Enable ATS (Applicant Tracking System) compatibility check
ENABLE_ATS_CHECK=true

# Enable skill matching against job descriptions
ENABLE_SKILL_MATCHING=true

# Enable experience level assessment
ENABLE_EXPERIENCE_ANALYSIS=true

# Enable education verification
ENABLE_EDUCATION_ANALYSIS=true

# Minimum score threshold (0-100)
MIN_PASSING_SCORE=60

# ----------------------------------------------------------------------------
# CORS SETTINGS
# ----------------------------------------------------------------------------
# Control which domains can access the API
# In development, allow localhost
# In production, set to your frontend domain

# Allowed origins (comma-separated)
# Example: http://localhost:3000,https://myapp.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------------------------------------------
# RATE LIMITING (Optional)
# ----------------------------------------------------------------------------
# Prevent API abuse

# Enable rate limiting
ENABLE_RATE_LIMITING=false

# Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
# Configure application logging

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to log to console only)
LOG_FILE=./logs/app.log

# ----------------------------------------------------------------------------
# DATABASE (Optional - for future enhancements)
# ----------------------------------------------------------------------------
# Uncomment if you add database support

# DATABASE_URL=postgresql://user:password@localhost:5432/resume_analyzer
# DATABASE_URL=sqlite:///./resume_analyzer.db

# ----------------------------------------------------------------------------
# REDIS CACHE (Optional - for performance)
# ----------------------------------------------------------------------------
# Uncomment if you add caching

# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
# Security-related settings

# Secret key for JWT tokens (if you add authentication)
# Generate with: openssl rand -hex 32
# SECRET_KEY=your_secret_key_here

# JWT token expiration in minutes
# TOKEN_EXPIRE_MINUTES=30

# ----------------------------------------------------------------------------
# NOTES FOR INTERVIEWS
# ----------------------------------------------------------------------------
# Be ready to explain:
# 1. Why we use environment variables (security, flexibility)
# 2. Why we have .env.example (documentation, onboarding)
# 3. Why we never commit .env (contains secrets)
# 4. How to generate secure keys (openssl, secrets module)
# 5. Different configs for dev/staging/production
# ============================================================================